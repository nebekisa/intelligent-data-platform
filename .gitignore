# .gitignore
# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual Environment
venv/
.env/
.venv/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Data files (we'll track small samples, but not large data)
*.csv
*.json
*.db
*.sqlite
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# Logs
*.log
logs/

# OS
.DS_Store
Thumbs.db

# Secrets
config.ini
.secrets/
*.key
*.pem